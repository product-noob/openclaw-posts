---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

posts.sort((a, b) => (b.data.date?.valueOf() || 0) - (a.data.date?.valueOf() || 0));
---
<BaseLayout title="Morning Brief — Daily AI/Tech Digest">
  <div class="container">
    <div class="feed-header">
      <h1 class="feed-header__title">All Digests</h1>
      <p class="feed-header__subtitle">Curated insights on AI models, agentic systems, and conversational commerce.</p>
    </div>

    <div class="posts-list">
      {posts.length === 0 ? (
        <div class="empty-state">📭 No posts found yet.</div>
      ) : (
        posts.map((post, index) => (
          <a href={`${import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/'}${post.id}/`} class="post-card animate-fade-in" style={`animation-delay: ${index * 0.08}s; opacity: 0;`}>
            <div class="post-card__date">
              {post.data.date ? post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' }) : post.id.replace('.md','')}
            </div>
            <h2 class="post-card__title">{post.data.title}</h2>
            {post.data.description && <p class="post-card__desc">{post.data.description}</p>}
            <div class="post-card__footer">
              <span class="post-card__read">Read digest →</span>
            </div>
          </a>
        ))
      )}
    </div>
  </div>
</BaseLayout>

<style>
.feed-header {
  margin-bottom: 2.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--border-light);
}
.feed-header__title {
  font-family: 'Source Serif 4', Georgia, serif;
  font-size: 2rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 0.5rem;
  letter-spacing: -0.025em;
}
.feed-header__subtitle {
  font-size: 0.95rem;
  color: var(--text-tertiary);
}

.empty-state {
  padding: 3rem;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 1rem;
  background: var(--surface-raised);
  border: 1px dashed var(--border);
  border-radius: var(--radius-lg);
}

.post-card {
  background: var(--surface);
  border: 1px solid var(--border-light);
  border-radius: var(--radius);
  padding: 1.5rem;
  margin-bottom: 0.75rem;
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  cursor: pointer;
  display: block;
  text-decoration: none;
  color: inherit;
}
.post-card:hover {
  box-shadow: var(--shadow-md);
  border-color: var(--border);
  text-decoration: none;
  transform: translateY(-3px);
}

.post-card__date {
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-tertiary);
  margin-bottom: 0.5rem;
}
.post-card__title {
  font-family: 'Source Serif 4', Georgia, serif;
  font-size: 1.2rem;
  font-weight: 700;
  line-height: 1.35;
  color: var(--text);
  margin-bottom: 0.5rem;
  letter-spacing: -0.01em;
}
.post-card__desc {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.6;
}
.post-card__footer {
  margin-top: 1rem;
  display: flex;
  justify-content: flex-end;
}
.post-card__read {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--accent);
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  display: inline-block;
}
.post-card:hover .post-card__read {
  transform: translateX(4px);
}
</style>
